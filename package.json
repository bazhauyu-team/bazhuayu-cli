{
  "name": "bazhuayu-cli",
  "version": "0.1.4",
  "description": "Standalone Octoparse engine CLI that runs local Chrome-based collection without the Electron client.",
  "private": false,
  "type": "module",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/bazhauyu-team/bazhuayu-cli.git"
  },
  "bugs": {
    "url": "https://github.com/bazhauyu-team/bazhuayu-cli/issues"
  },
  "homepage": "https://github.com/bazhauyu-team/bazhuayu-cli#readme",
  "files": [
    "dist",
    "schemas",
    "examples",
    "README.md",
    "SECURITY.md",
    "RUNTIME_SECURITY_NOTICE.txt"
  ],
  "bin": {
    "octo-engine": "dist/index.js"
  },
  "scripts": {
    "build": "tsc",
    "dev": "tsx src/index.ts",
    "release": "node scripts/release.mjs",
    "start": "node dist/index.js",
    "test": "npm run build && node --test --test-concurrency=1 test/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "engines": {
    "node": ">=20"
  },
  "dependencies": {
    "@octopus/engine": "1.0.21",
    "fast-xml-parser": "4.5.0",
    "ws": "^8.18.3"
  },
  "bundledDependencies": [
    "@octopus/engine",
    "fast-xml-parser",
    "ws"
  ],
  "devDependencies": {
    "@types/node": "^20.0.0",
    "@types/ws": "^8.5.14",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0"
  }
}
